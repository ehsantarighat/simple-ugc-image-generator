# --- Required ---------------------------------------------------------------
# Your OpenAI API key. Server-only — never ship this to the frontend.
OPENAI_API_KEY=

# --- Optional ---------------------------------------------------------------
# "development" | "production"
APP_ENV=production

# Maximum allowed upload size for each image, in megabytes.
MAX_UPLOAD_MB=20

# Image model to call. Spec defaults to gpt-image-2; override here if you
# need to point at a different model id (e.g. gpt-image-1).
DEFAULT_IMAGE_MODEL=gpt-image-2

# Comma-separated list of allowed CORS origins. Leave unset to allow all
# (fine when the API and frontend are served from the same Railway service).
# Example: https://your-app.up.railway.app,http://localhost:5173
CORS_ORIGINS=
