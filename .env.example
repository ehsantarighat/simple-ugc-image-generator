# --- Supabase ---------------------------------------------------------------
# Public project URL. Safe for the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Public anon key. Safe for the browser. RLS protects data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key. Server-only. Used by the generation pipeline to upload
# generated images on behalf of the authenticated user (after we verify them).
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI -----------------------------------------------------------------
# Server-only. Used to call GPT Image 2.
OPENAI_API_KEY=

# Image model id. Default: gpt-image-2. Some accounts may only have access
# to gpt-image-1 — set that here if needed.
OPENAI_IMAGE_MODEL=gpt-image-2

# --- App --------------------------------------------------------------------
# Used when constructing absolute URLs (e.g. callbacks). Leave unset locally.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Max upload size per image, in megabytes. Enforced in server actions.
MAX_UPLOAD_MB=15
