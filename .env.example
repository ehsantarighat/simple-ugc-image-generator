# --- Supabase ---------------------------------------------------------------
# Public project URL. Safe for the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Public anon key. Safe for the browser. RLS protects data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key. Server-only.
SUPABASE_SERVICE_ROLE_KEY=

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
MAX_UPLOAD_MB=15

# ============================================================================
# IMAGE PROVIDERS
# ----------------------------------------------------------------------------
# OPENAI_API_KEY is required (primary provider, premium tier).
# Every other provider is optional — the registry picks whatever is available
# that matches the request's qualityPriority and capability needs.
# ============================================================================

# --- OpenAI (GPT Image 2) — REQUIRED ---------------------------------------
# Get one: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2

# --- Seedream (BytePlus ModelArk) — OPTIONAL --------------------------------
# Console: https://console.byteplus.com/ark/  → API Keys
# IMPORTANT: the "model" must be either a public Doubao/Seedream model id
# (Model API → Model catalog) or a custom endpoint id you created in
# Endpoints (looks like "ep-20240xxx-xxxxx").
# "seedream-4-5" is NOT a valid model id and will 404.
SEEDREAM_API_KEY=
SEEDREAM_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
SEEDREAM_MODEL_HIGH_QUALITY=doubao-seedream-4-0-250828
SEEDREAM_MODEL_LITE=doubao-seedream-3-0-t2i-250415

# --- Qwen (Alibaba Model Studio) — OPTIONAL ---------------------------------
# Console: https://modelstudio.console.alibabacloud.com/ (intl)
#       or https://bailian.console.aliyun.com/ (China region)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1
QWEN_IMAGE_EDIT_MODEL_PLUS=qwen-image-edit-plus
QWEN_IMAGE_EDIT_MODEL_MAX=qwen-image-edit-max

# --- Gemini (Google AI Studio) — OPTIONAL ----------------------------------
# Console: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_IMAGE_MODEL_FLASH=gemini-2.5-flash-image
GEMINI_IMAGE_MODEL_PRO=gemini-2.5-pro-image

# --- Recraft V3 — OPTIONAL (replaces FLUX/BFL slot) -------------------------
# Purpose-built for product photography + brand imagery, strong logo/text fidelity.
# Console: https://www.recraft.ai/ → API → keys
RECRAFT_API_KEY=
RECRAFT_BASE_URL=https://external.api.recraft.ai/v1
RECRAFT_MODEL=recraftv3

# --- fal.ai aggregator — RECOMMENDED for additional models ------------------
# One key gives access to FLUX Pro Kontext, Nano Banana Edit (Gemini), Recraft,
# Imagen 4, Ideogram, plus video models (Kling, Veo, Hailuo, LTX). Dashboard:
# https://fal.ai/dashboard → API Keys. Add a payment method on the Billing
# page before generation will succeed.
FAL_KEY=
